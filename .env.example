# =============================================================================
# Knowledge Harvester Pipeline -- Environment Variables
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env

# -- Authentication --------------------------------------------------------
AUTH_MODE=dev
JWT_DEV_SECRET=change-me-in-production
AZURE_AD_AUDIENCE=

# Azure AD (required for Graph API polling)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -- Service URLs ----------------------------------------------------------
# These are overridden in docker-compose.yml to use container hostnames.
# The values below are for running outside Docker (bare-metal / dev).
NATS_URL=nats://localhost:4222
LLM_BASE_URL=http://localhost:8000/v1
LLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
LLM_MAX_MODEL_LEN=8192
# LLM_QUANTIZATION=         # Set to awq or gptq only for quantized models
MUNINNDB_URL=https://your-muninndb-instance.com
MUNINNDB_API_KEY=your-api-key

# -- Pipeline tuning -------------------------------------------------------
POLL_INTERVAL_MS=60000
MAX_CONCURRENT_EXTRACTIONS=8

# -- Logging ---------------------------------------------------------------
LOG_LEVEL=info

# -- RunPod (only used by Dockerfile.runpod / start.sh) --------------------
# DATA_DIR=/data             # Persistent storage path on RunPod
# HF_HOME=/data/huggingface  # HuggingFace model cache
